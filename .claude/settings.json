{
  "permissions": {
    "deny": ["Read(.env)", "Read(.env.*)"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block_env.py\""
          }
        ]
      }
    ]
  }
}
